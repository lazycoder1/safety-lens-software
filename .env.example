# SafetyLens Environment Variables
# Copy this file to .env and fill in values

# Database
DATABASE_URL=postgresql://safetylens:safetylens@localhost:5432/safetylens

# Authentication
JWT_SECRET=          # Leave empty for random key (tokens invalidate on restart)

# Backend
SAFETYLENS_ENV=dev   # dev | prod (controls logging format)
SAFETYLENS_LOG_LEVEL=INFO  # DEBUG | INFO | WARNING | ERROR
SAFETYLENS_PORT=8000

# VLM (Ollama)
OLLAMA_URL=http://localhost:11434/api/generate

# Frontend (Vite build-time variables)
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000

# PostgreSQL (used by docker-compose)
POSTGRES_USER=safetylens
POSTGRES_PASSWORD=safetylens
POSTGRES_DB=safetylens

# Testing
TEST_DATABASE_URL=postgresql://localhost:5432/safetylens_test
